RSF_USER=
RSF_PASS=
RSF_USER_ID=
# Last resort if RSF has banned our IP: route requests through a rotating
# free proxy (proxifly/free-proxy-list). Off by default — unreliable, and
# routes creds through a third-party proxy, so only flip on when actually banned.
# RSF_PROXY_ENABLED=true
# How many dead proxies to rotate through before giving up on a request.
# RSF_PROXY_MAX_ATTEMPTS=4

# Persistence. Leave DATABASE_URL empty for local sqlite (SQLITE_PATH or
# ./data/dev.sqlite). Set DATABASE_URL in prod to use Postgres.
# DATABASE_URL=postgres://rsf:rsf@localhost:5432/rsf
# SQLITE_PATH=./data/dev.sqlite

# Discord bot (manage watched rallies). See docs/discord.md for setup.
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
# Comma-separated Discord user ids allowed to run commands.
DISCORD_ALLOWED_USER_IDS=

# Cron scraper (periodically scrapes watched rallies, posts new comments).
# Channel the per-run summary is posted to (numeric channel id).
DISCORD_RESULTS_CHANNEL_ID=
# Leave CRON_SCHEDULE empty to run one pass and exit (drive from system cron);
# set a cron expression to self-schedule in-process via Bun.cron (UTC).
# CRON_SCHEDULE=*/15 * * * *
# Throttling: each RSF request waits a random delay in this range (ms).
# CRON_DELAY_MIN_MS=10000
# CRON_DELAY_MAX_MS=20000
